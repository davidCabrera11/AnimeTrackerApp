<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="24dp"
    android:background="@drawable/bg_rounded_anime_item"
    android:elevation="4dp"
    android:paddingBottom="8dp">

    <ImageView
        android:id="@+id/image_anime"
        android:layout_width="0dp"
        android:layout_height="434dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:contentDescription="Anime Image"
        android:scaleType="fitXY"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_anime_rank"
        android:layout_width="43dp"
        android:layout_height="28dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_rounded_textview"
        android:clickable="false"
        android:paddingTop="5dp"
        android:text="#%d"
        android:textAlignment="center"
        android:textColor="@color/white"
        app:cornerRadius="16dp"
        app:layout_constraintStart_toStartOf="@+id/image_anime"
        app:layout_constraintTop_toTopOf="@+id/image_anime"
        tools:text="#1" />


    <TextView
        android:id="@+id/tv_anime_title"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:fontFamily="@font/manrope_bold"
        android:textColor="#181C22"
        android:textSize="20sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/image_anime"
        tools:text="Fullmetal Alchemist:Brotherhood" />

    <ImageView
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginEnd="8dp"
        android:contentDescription="score star"
        android:src="@drawable/ic_star"
        app:layout_constraintBottom_toBottomOf="@+id/tv_anime_score"
        app:layout_constraintEnd_toStartOf="@+id/tv_anime_score"
        app:layout_constraintTop_toTopOf="@+id/tv_anime_score" />

    <TextView
        android:id="@+id/tv_anime_score"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:fontFamily="@font/manrope_extrabold"
        android:textAlignment="textEnd"
        android:textColor="#0D3989"
        android:textSize="24sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/tv_anime_title"
        tools:text="9.13" />

    <TextView
        android:id="@+id/tv_anime_global_score"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="16dp"
        android:fontFamily="@font/inter_bold"
        android:textAlignment="center"
        android:textColor="#747783"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_anime_score"
        tools:text="GLOBAL SCORE" />

    <ImageView
        android:id="@+id/img_tv"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:layout_marginStart="16dp"
        android:contentDescription="score star"
        android:src="@drawable/ic_tv"
        app:layout_constraintBottom_toBottomOf="@+id/tv_anime_type"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/tv_anime_type" />

    <TextView
        android:id="@+id/tv_anime_type"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:fontFamily="@font/inter_medium"
        android:text="%s (%s eps)"
        app:layout_constraintStart_toEndOf="@+id/img_tv"
        app:layout_constraintTop_toBottomOf="@+id/tv_anime_title"
        tools:text="TV (64 eps)" />

    <ImageView
        android:id="@+id/img_calendar"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:layout_marginStart="16dp"
        android:contentDescription="score star"
        android:src="@drawable/ic_calendar"
        app:layout_constraintBottom_toBottomOf="@+id/tv_anime_aired_dates"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/tv_anime_aired_dates" />


    <TextView
        android:id="@+id/tv_anime_aired_dates"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="12dp"
        android:fontFamily="@font/inter_medium"
        android:text="Apr 2009 - Jul 2010"
        app:layout_constraintStart_toEndOf="@+id/img_calendar"
        app:layout_constraintTop_toBottomOf="@+id/tv_anime_type"
        tools:text="Apr 2009 - Jul 2010" />

    <ImageButton
        android:layout_width="25dp"
        android:layout_height="25dp"
        android:layout_marginTop="32dp"
        android:layout_marginEnd="16dp"
        android:background="@color/white"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_favorite"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_anime_global_score" />


</androidx.constraintlayout.widget.ConstraintLayout>